{
    "name": "apermo/site-bookkeeper-reporter",
    "description": "A WordPress site-bookkeeper-reporter plugin.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Christoph Daum",
            "email": "me@christoph-daum.de"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "apermo/apermo-coding-standards": "^2.0",
        "apermo/phpstan-wordpress-rules": "^0.2",
        "brain/monkey": "^2.6",
        "phpstan/extension-installer": "^1.4",
        "phpunit/phpunit": "^11.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "yoast/phpunit-polyfills": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Apermo\\SiteBookkeeperReporter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Apermo\\SiteBookkeeperReporter\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "analyse": "phpstan analyse --memory-limit=1G",
        "cs": "phpcs --warning-severity=0",
        "cs:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}
